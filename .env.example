# J-Star FYB Service Configuration
# Copy this to .env and fill in your keys

# ==============================================
# DATABASE
# ==============================================
# Local development (SQLite)
DATABASE_URL="file:./dev.db"
DATABASE_PROVIDER="sqlite"

# Production (PostgreSQL/Neon) - uncomment and use these in production:
# DATABASE_URL="postgresql://user:password@host:port/database"
# DATABASE_PROVIDER="postgresql"

# ==============================================
# BETTER AUTH
# ==============================================
# Required: Secret key for signing sessions (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your_secret_key_here

# Production URL (set to your domain in production)
BETTER_AUTH_URL=http://localhost:3000

# Required for OAuth: Google OAuth credentials from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ==============================================
# AI PROVIDERS
# ==============================================
# Required: Google API key for Gemini embeddings
GOOGLE_API_KEY=your_google_api_key_here

# Required: Groq API key for LLM
GROQ_API_KEY=your_groq_api_key_here

# Required: Gemini API key (can be same as GOOGLE_API_KEY)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override the default model
# REVIEW_MODEL_NAME=moonshotai/kimi-k2-instruct-0905

# Optional: Semantic Scholar API key for higher rate limits
# Get a free key at: https://www.semanticscholar.org/product/api
# With key: 5000 req/5min, Without: 100 req/5min
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# ==============================================
# PAYMENTS (Paystack)
# ==============================================
# Required for payments
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here

# ==============================================
# EMAIL (Resend)
# ==============================================
# Required for email notifications
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL="J-Star Projects <noreply@yourdomain.com>"

# ==============================================
# ADMIN
# ==============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ==============================================
# APP
# ==============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required for Partner/Influencer Auth
PARTNER_AUTH_SECRET=your_partner_auth_secret_here

# ==============================================
# RATE LIMITING (Upstash Redis)
# ==============================================
# Optional but recommended for production
# Get free tier at: https://upstash.com
# UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
# UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# Optional: Override the embedding model
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
