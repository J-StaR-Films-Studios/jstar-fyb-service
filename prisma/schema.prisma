generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                      @id
  name                   String
  email                  String                      @unique
  emailVerified          Boolean                     @default(false)
  image                  String?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  role                   String                      @default("USER")
  accounts               Account[]
  notifications          InAppNotification[]
  payments               Payment[]
  projects               Project[]
  sessions               Session[]
  notificationPreference UserNotificationPreference?
  // Referral tracking
  referredById           String?
  referredBy             Influencer?                 @relation("ReferredUsers", fields: [referredById], references: [id])

  // Bolt: Add index for frequent queries by referredById
  @@index([referredById])
  // Bolt: Add index for sorting by createdAt in dashboards
  @@index([createdAt])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Lead {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  whatsapp    String   @unique
  department  String
  topic       String
  twist       String
  complexity  Int
  status      String   @default("NEW")
  userId      String?
  anonymousId String?
  tier        String? // e.g., "AGENCY_SOFT_LIFE"
  source      String   @default("JAY_CHAT") // "JAY_CHAT", "AGENCY_FORM", "DIRECT"
  name        String? // User's name (for leads without user accounts yet)
  email       String? // Email (for leads without user accounts yet)

  // Bolt: Add indexes for frequent lookups
  @@index([userId])
  @@index([anonymousId])
  // Bolt: Add index for filtering by status in dashboards
  @@index([status])
  // Bolt: Add index for sorting by createdAt in dashboards
  @@index([createdAt])
}

model Conversation {
  id          String    @id @default(cuid())
  userId      String?
  anonymousId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  title       String?
  messages    Message[]

  // Bolt: Add indexes for frequent lookups
  @@index([userId])
  @@index([anonymousId])
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  role            String
  content         String
  toolInvocations Json?
  createdAt       DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Project {
  id                       String                @id @default(cuid())
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  userId                   String?
  anonymousId              String?
  topic                    String
  twist                    String?
  abstract                 String?
  mode                     String                @default("DIY")
  status                   String                @default("OUTLINE_GENERATED")
  assignedTo               String?
  isUnlocked               Boolean               @default(false)
  outlineGenerated         Boolean               @default(false)
  isLocked                 Boolean               @default(false)
  lockedAt                 DateTime?
  topicSwitchCount         Int                   @default(0)
  progressPercentage       Int                   @default(0)
  contentProgress          Json?
  documentProgress         Json?
  aiGenerationStatus       Json?
  timeTracking             Json?
  milestones               Json?
  estimatedCompletion      DateTime?
  actualCompletion         DateTime?
  fileSearchStoreId        String?
  fileSearchStoreCreatedAt DateTime?
  department               String?
  course                   String?
  institution              String?
  complexity               Int?                  @default(3)
  jayContextSummary        String?
  contextComplete          Boolean               @default(false)
  chapters                 Chapter[]
  outline                  ChapterOutline?
  payments                 Payment[]
  user                     User?                 @relation(fields: [userId], references: [id])
  conversations            ProjectConversation[]
  messages                 ProjectMessage[]
  documents                ResearchDocument[]
  diagrams                 ProjectDiagram[]

  // Bolt: Optimized index for dashboard sorting (userId + updatedAt)
  @@index([userId, updatedAt])
  // Bolt: Add index for frequent queries by anonymousId
  @@index([anonymousId])
  // Bolt: Add index for sorting by updatedAt in dashboards
  @@index([updatedAt])
}

model Payment {
  id              String        @id @default(cuid())
  amount          Float
  currency        String        @default("NGN")
  status          String        @default("PENDING")
  reference       String        @unique
  gatewayResponse String?
  userId          String
  projectId       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  project         Project       @relation(fields: [projectId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
  // Discount tracking
  discountCodeId  String?
  discountAmount  Float         @default(0)
  discountCode    DiscountCode? @relation(fields: [discountCodeId], references: [id])
  // Commission tracking
  commission      Commission?

  @@index([userId])
  // Bolt: Add index for frequent queries by projectId
  @@index([projectId])
  @@index([discountCodeId])
  // Bolt: Add index for sorting by createdAt in dashboards
  @@index([createdAt])
  // Bolt: Add index for filtering by status in dashboards
  @@index([status])
}

model ResearchDocument {
  id                   String    @id @default(cuid())
  projectId            String
  fileUrl              String?
  fileData             Bytes?
  mimeType             String?
  fileName             String
  fileType             String
  status               String    @default("PENDING")
  processedAt          DateTime?
  title                String?
  author               String?
  year                 String?
  documentType         String?
  category             String?
  objective            String?
  motivation           String?
  methodology          String?
  contribution         String?
  limitations          String?
  keywords             String?
  themes               String?
  summary              String?
  insights             String?
  extractedContent     String?
  aiInsights           String?
  importedToFileSearch Boolean   @default(false)
  fileSearchFileId     String?
  importError          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  project              Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ChapterOutline {
  id        String   @id @default(cuid())
  projectId String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Chapter {
  id               String    @id @default(cuid())
  projectId        String
  number           Int
  title            String
  content          String
  sections         Json?
  version          Int       @default(1)
  previousVersions Json?
  status           String    @default("DRAFT")
  wordCount        Int       @default(0)
  generatedAt      DateTime?
  lastEditedAt     DateTime?
  generationPrompt String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId])
}

model ProjectMessage {
  id        String   @id @default(cuid())
  projectId String
  role      String
  content   String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Bolt: Add index for frequent queries by projectId
  @@index([projectId])
}

model ProjectDiagram {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  diagramType String
  mermaidCode String   @db.Text
  description String?  @db.Text
  version     Int      @default(1)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

model ProjectConversation {
  id        String   @id @default(cuid())
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Thread categorization
  threadType  String  @default("general") // "general", "chapter_1", ..., "research", "editing"
  threadTitle String? // User-facing title, e.g., "Chapter 1 Revisions"

  // Context scope (what this thread "sees")
  contextScope Json? // { chapterNumbers: [1, 2], includeResearch: true }

  isArchived Boolean @default(false)

  messages ProjectChatMessage[]
  project  Project              @relation(fields: [projectId], references: [id])

  @@index([projectId, threadType])
}

model ProjectChatMessage {
  id              String              @id @default(cuid())
  conversationId  String
  role            String
  content         String
  reasoning       String? // AI reasoning/thinking content (optional)
  toolInvocations Json?
  createdAt       DateTime            @default(now())
  conversation    ProjectConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
}

model TopicSwitchRequest {
  id          String    @id @default(cuid())
  userId      String
  projectId   String
  reason      String
  proofUrl    String?
  status      String    @default("pending")
  fee         Int?
  paymentRef  String?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  explanation String?

  // Bolt: Add indexes for frequent lookups
  @@index([userId])
  @@index([projectId])
  // Bolt: Add index for sorting by createdAt in dashboards
  @@index([createdAt])
}

model TopicSwitchArchive {
  id          String   @id @default(cuid())
  requestId   String
  projectId   String
  oldTopic    String
  oldTwist    String?
  oldAbstract String?
  oldOutline  Json?
  oldChapters Json?
  archivedAt  DateTime @default(now())

  @@index([projectId])
  @@index([requestId])
}

model InAppNotification {
  id          String    @id @default(cuid())
  userId      String
  type        String
  title       String
  message     String
  data        Json?
  priority    String    @default("medium")
  readAt      DateTime?
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model UserNotificationPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  emailEnabled Boolean  @default(true)
  inAppEnabled Boolean  @default(true)
  categories   Json?
  frequency    String   @default("immediate")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

// ============================================
// INFLUENCER REFERRAL & DISCOUNT SYSTEM
// ============================================

model Influencer {
  id               String       @id @default(cuid())
  name             String
  email            String       @unique
  phone            String?
  referralCode     String       @unique // e.g., "JOHNGPT", "TECHBRO"
  isActive         Boolean      @default(true)
  commissionRate   Float        @default(0.10) // 10% default
  referralDiscount Float        @default(0.0) // Discount for referred users (0-1.0)
  totalEarnings    Float        @default(0)
  pendingPayout    Float        @default(0)
  // Admin-controlled demo credits (in Naira)
  freeCredits      Float        @default(0) // e.g., 50000 = ₦50k worth of free usage
  creditsUsed      Float        @default(0) // Track how much they've used
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  referredUsers    User[]       @relation("ReferredUsers")
  commissions      Commission[]

  // Payout Details - Secured via Paystack Transfer Recipient
  payoutConfig InfluencerPayoutConfig?
}

model InfluencerPayoutConfig {
  id           String     @id @default(cuid())
  influencerId String     @unique
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  // Safe Fields (We do NOT store the full account number)
  bankName      String
  bankCode      String // e.g "058" (GTBank)
  accountName   String // as returned by Paystack Resolve
  recipientCode String // The Paystack Recipient Code (RCP_xxxx) - CRITICAL
  last4Digits   String // For UI display only
  currency      String @default("NGN")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Commission {
  id           String     @id @default(cuid())
  influencerId String
  paymentId    String     @unique
  amount       Float // Commission amount in Naira
  status       String     @default("PENDING") // PENDING, PAID
  paidAt       DateTime?
  createdAt    DateTime   @default(now())
  influencer   Influencer @relation(fields: [influencerId], references: [id])
  payment      Payment    @relation(fields: [paymentId], references: [id])

  @@index([influencerId])
}

model DiscountCode {
  id            String    @id @default(cuid())
  code          String    @unique // e.g., "NEWYEAR25"
  discountType  String    @default("PERCENTAGE") // PERCENTAGE, FIXED
  discountValue Float // 15 = 15% or ₦15 fixed
  maxUses       Int? // null = unlimited
  currentUses   Int       @default(0)
  minAmount     Float? // Minimum payment to qualify
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payments      Payment[]
}
