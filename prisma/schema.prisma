generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                      @id
  name                   String
  email                  String                      @unique
  emailVerified          Boolean                     @default(false)
  image                  String?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  role                   String                      @default("USER")
  referredById           String?
  accounts               Account[]
  notifications          InAppNotification[]
  payments               Payment[]
  projects               Project[]
  sessions               Session[]
  referredBy             Influencer?                 @relation("ReferredUsers", fields: [referredById], references: [id])
  notificationPreference UserNotificationPreference?

  @@index([createdAt])
  // Bolt: Index for referral lookups and counting
  @@index([referredById])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Bolt: Index for cascading deletes and user lookups

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Bolt: Index for cascading deletes and user lookups

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Lead {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  whatsapp    String   @unique
  department  String
  topic       String
  twist       String
  complexity  Int
  status      String   @default("NEW")
  userId      String?
  anonymousId String?
  tier        String?
  source      String?  @default("JAY_CHAT")
  name        String?
  email       String?

  @@index([anonymousId])
  @@index([createdAt])
  @@index([status])
  @@index([userId])
}

model Conversation {
  id          String    @id @default(cuid())
  userId      String?
  anonymousId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  title       String?
  messages    Message[]

  @@index([anonymousId])
  @@index([userId])
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  role            String
  content         String
  toolInvocations Json?
  createdAt       DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Project {
  id                       String                @id @default(cuid())
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  userId                   String?
  anonymousId              String?
  topic                    String
  twist                    String?
  abstract                 String?
  mode                     String                @default("DIY")
  status                   String                @default("OUTLINE_GENERATED")
  assignedTo               String?
  isUnlocked               Boolean               @default(false)
  outlineGenerated         Boolean               @default(false)
  isLocked                 Boolean               @default(false)
  lockedAt                 DateTime?
  topicSwitchCount         Int                   @default(0)
  progressPercentage       Int                   @default(0)
  contentProgress          Json?
  documentProgress         Json?
  aiGenerationStatus       Json?
  timeTracking             Json?
  milestones               Json?
  estimatedCompletion      DateTime?
  actualCompletion         DateTime?
  fileSearchStoreId        String?
  fileSearchStoreCreatedAt DateTime?
  department               String?
  course                   String?
  institution              String?
  complexity               Int?                  @default(3)
  jayContextSummary        String?
  contextComplete          Boolean               @default(false)
  chapters                 Chapter[]
  outline                  ChapterOutline?
  payments                 Payment[]
  user                     User?                 @relation(fields: [userId], references: [id])
  conversations            ProjectConversation[]
  diagrams                 ProjectDiagram[]
  messages                 ProjectMessage[]
  documents                ResearchDocument[]

  @@index([userId])
  @@index([anonymousId])
  @@index([updatedAt])
}

model Payment {
  id              String        @id @default(cuid())
  amount          Float
  currency        String        @default("NGN")
  status          String        @default("PENDING")
  reference       String        @unique
  gatewayResponse String?
  userId          String
  projectId       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  discountAmount  Float         @default(0)
  discountCodeId  String?
  commission      Commission?
  discountCode    DiscountCode? @relation(fields: [discountCodeId], references: [id])
  project         Project       @relation(fields: [projectId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([discountCodeId])
  @@index([projectId])
}

model ResearchDocument {
  id                   String    @id @default(cuid())
  projectId            String
  fileUrl              String?
  fileData             Bytes?
  mimeType             String?
  fileName             String
  fileType             String
  status               String    @default("PENDING")
  processedAt          DateTime?
  title                String?
  author               String?
  year                 String?
  documentType         String?
  category             String?
  objective            String?
  motivation           String?
  methodology          String?
  contribution         String?
  limitations          String?
  keywords             String?
  themes               String?
  summary              String?
  insights             String?
  extractedContent     String?
  aiInsights           String?
  importedToFileSearch Boolean   @default(false)
  fileSearchFileId     String?
  importError          String?
// Hybrid Research Feature - Academic metadata from Semantic Scholar
  sourceType           String    @default("WEB") // "ACADEMIC", "WEB", or "USER_UPLOAD"
  citationCount        Int?
  openAccessUrl        String?
  abstractText         String?
  snippet              String?
  authors              String? // Comma-separated author names
  venue                String? // Journal/conference name
  semanticScholarId    String? // Paper ID for deduplication
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  project              Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ChapterOutline {
  id        String   @id @default(cuid())
  projectId String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Chapter {
  id               String    @id @default(cuid())
  projectId        String
  number           Int
  title            String
  content          String
  sections         Json?
  version          Int       @default(1)
  previousVersions Json?
  status           String    @default("DRAFT")
  wordCount        Int       @default(0)
  generatedAt      DateTime?
  lastEditedAt     DateTime?
  generationPrompt String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId])
}

model ProjectMessage {
  id        String   @id @default(cuid())
  projectId String
  role      String
  content   String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectDiagram {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  diagramType String
  mermaidCode String
  description String?
  version     Int      @default(1)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectConversation {
  id           String               @id @default(cuid())
  projectId    String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  contextScope Json?
  isArchived   Boolean              @default(false)
  threadTitle  String?
  threadType   String               @default("general")
  messages     ProjectChatMessage[]
  project      Project              @relation(fields: [projectId], references: [id])

  @@index([projectId, threadType])
}

model ProjectChatMessage {
  id              String              @id @default(cuid())
  conversationId  String
  role            String
  content         String
  toolInvocations Json?
  createdAt       DateTime            @default(now())
  reasoning       String?
  conversation    ProjectConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
}

model TopicSwitchRequest {
  id          String    @id @default(cuid())
  userId      String
  projectId   String
  reason      String
  proofUrl    String?
  status      String    @default("pending")
  fee         Int?
  paymentRef  String?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  explanation String?
  // Bolt: Index for looking up requests by user

  @@index([createdAt])
  @@index([projectId])
  // Bolt: Index for filtering requests by project and status
  @@index([projectId, status])
  @@index([userId])
}

model TopicSwitchArchive {
  id          String   @id @default(cuid())
  requestId   String
  projectId   String
  oldTopic    String
  oldTwist    String?
  oldAbstract String?
  oldOutline  Json?
  oldChapters Json?
  archivedAt  DateTime @default(now())

  @@index([projectId])
  @@index([requestId])
}

model InAppNotification {
  id          String    @id @default(cuid())
  userId      String
  type        String
  title       String
  message     String
  data        Json?
  priority    String    @default("medium")
  readAt      DateTime?
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model UserNotificationPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  emailEnabled Boolean  @default(true)
  inAppEnabled Boolean  @default(true)
  categories   Json?
  frequency    String   @default("immediate")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model Influencer {
  id               String                  @id @default(cuid())
  name             String
  email            String                  @unique
  phone            String?
  referralCode     String                  @unique
  isActive         Boolean                 @default(true)
  commissionRate   Float                   @default(0.10)
  totalEarnings    Float                   @default(0)
  pendingPayout    Float                   @default(0)
  freeCredits      Float                   @default(0)
  creditsUsed      Float                   @default(0)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  referralDiscount Float?                  @default(0.0) @db.Real
  commissions      Commission[]
  payoutConfig     InfluencerPayoutConfig?
  referredUsers    User[]                  @relation("ReferredUsers")
}

model InfluencerPayoutConfig {
  id            String     @id @default(cuid())
  influencerId  String     @unique
  bankName      String
  bankCode      String
  accountName   String
  recipientCode String
  last4Digits   String
  currency      String     @default("NGN")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
}

model Commission {
  id           String     @id @default(cuid())
  influencerId String
  paymentId    String     @unique
  amount       Float
  status       String     @default("PENDING")
  paidAt       DateTime?
  createdAt    DateTime   @default(now())
  influencer   Influencer @relation(fields: [influencerId], references: [id])
  payment      Payment    @relation(fields: [paymentId], references: [id])

  // Bolt: Index for fetching influencer commissions by status
  @@index([influencerId, status])
}

model DiscountCode {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    @default("PERCENTAGE")
  discountValue Float
  maxUses       Int?
  currentUses   Int       @default(0)
  minAmount     Float?
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payments      Payment[]
}
